<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header judul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/surface">

        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Jadwal Sholat"
            android:textColor="@color/gold_soft"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kemenag RI · Surabaya"
            android:textColor="@color/text_muted2"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Header kolom tabel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@color/surface2">

        <TextView android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="Tgl" android:textColor="@color/gold_soft"
            android:textSize="10sp" android:textStyle="bold" android:gravity="center" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Subuh"
            android:textColor="@color/text_muted2" android:textSize="10sp" android:gravity="center" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Dzuhur"
            android:textColor="@color/text_muted2" android:textSize="10sp" android:gravity="center" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Ashar"
            android:textColor="@color/text_muted2" android:textSize="10sp" android:gravity="center" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Maghrib"
            android:textColor="@color/text_muted2" android:textSize="10sp" android:gravity="center" />

        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Isya"
            android:textColor="@color/text_muted2" android:textSize="10sp" android:gravity="center" />

    </LinearLayout>

    <!-- Loading -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="@color/gold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mengambil data..."
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Tabel data -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvJadwal"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:visibility="gone"
        android:paddingBottom="4dp"
        android:clipToPadding="false" />

    <!-- Error -->
    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:text="Gagal memuat data.\nPeriksa koneksi internet."
        android:textColor="@color/red"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Tombol bawah -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTerapkan"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Terapkan Hari Ini"
            android:textSize="12sp"
            android:textColor="#080c10"
            app:backgroundTint="@color/gold"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTutup"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Tutup"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            app:backgroundTint="@color/surface2"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp"
            app:cornerRadius="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</LinearLayout>