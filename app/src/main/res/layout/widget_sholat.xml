<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <TextView
        android:id="@+id/tvWidgetProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0/5"
        android:textColor="#e2c97e"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="6dp">

        <TextView android:id="@+id/tvSholat1"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="Sub" android:textColor="#9aa5b4" android:textSize="10sp" />

        <TextView android:id="@+id/tvSholat2"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="Dzu" android:textColor="#9aa5b4" android:textSize="10sp" />

        <TextView android:id="@+id/tvSholat3"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="Ash" android:textColor="#9aa5b4" android:textSize="10sp" />

        <TextView android:id="@+id/tvSholat4"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="Mag" android:textColor="#9aa5b4" android:textSize="10sp" />

        <TextView android:id="@+id/tvSholat5"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:gravity="center"
            android:text="Isy" android:textColor="#9aa5b4" android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>