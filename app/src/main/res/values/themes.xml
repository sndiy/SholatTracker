<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SholatTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_soft</item>
        <item name="colorOnPrimary">@color/bg</item>
        <item name="colorSecondary">@color/green</item>
        <item name="colorOnSecondary">@color/bg</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
