<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/surface2"
    app:cardCornerRadius="14dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp"
    app:cardElevation="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbSholat"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="14dp"
            android:clickable="false"
            android:focusable="false"
            android:button="@null"
            android:background="@drawable/checkbox_selector" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/tvArabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted2"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_muted2"
                android:textSize="11sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNext"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="Selanjutnya"
                android:textSize="9sp"
                android:textColor="@color/gold"
                android:visibility="gone"
                app:chipBackgroundColor="@color/gold_dim"
                app:chipStrokeColor="@color/gold_border"
                app:chipStrokeWidth="1dp"
                app:chipMinHeight="24dp"
                android:clickable="false"
                app:ensureMinTouchTargetSize="false"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
